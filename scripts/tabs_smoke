#!/usr/bin/env sh
set -eu

repo_dir="$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)"
cd "$repo_dir"

if [ ! -x "$repo_dir/commander" ]; then
  make commander >/dev/null
fi

sequence='[
  {"command_id":"panel.open_path","argument":"file:///Users/sergey/Projects/Crystal/commander"},
  {"command_id":"tab.new"},
  {"command_id":"tab.rename","argument":"Work"},
  {"command_id":"panel.open_path","argument":"file:///Users/sergey/Projects/Crystal"},
  {"command_id":"tab.previous"},
  {"command_id":"tab.next"}
]'

json="$(COMMANDER_AUTOMATION_COMMANDS_JSON="$sequence" "$repo_dir/commander")"
printf '%s\n' "$json" | python3 -c '
import json
import sys

data = json.load(sys.stdin)
snapshot = data["snapshot"]
tabs = snapshot["tabs"]
assert len(tabs) == 2, len(tabs)
assert snapshot["active_tab"] == 1, snapshot["active_tab"]
assert tabs[1]["title"] == "Work", tabs[1]["title"]
assert tabs[0]["panel_uris"][0].endswith("/commander"), tabs[0]["panel_uris"][0]
assert tabs[1]["panel_uris"][0].endswith("/Crystal"), tabs[1]["panel_uris"][0]
print("{} tabs; active={}; tab0={}; tab1={}".format(len(tabs), snapshot["active_tab"], tabs[0]["panel_uris"][0], tabs[1]["panel_uris"][0]))
'

panel_count_sequence='[
  {"command_id":"tab.new"},
  {"command_id":"tab.set_panel_count","argument":"4"},
  {"command_id":"tab.previous"},
  {"command_id":"tab.next"}
]'

panel_count_json="$(COMMANDER_AUTOMATION_COMMANDS_JSON="$panel_count_sequence" "$repo_dir/commander")"
printf '%s\n' "$panel_count_json" | python3 -c '
import json
import sys

data = json.load(sys.stdin)
snapshot = data["snapshot"]
tabs = snapshot["tabs"]
assert len(tabs) == 2, len(tabs)
assert snapshot["active_tab"] == 1, snapshot["active_tab"]
assert tabs[0]["panel_count"] == 2, tabs[0]["panel_count"]
assert tabs[1]["panel_count"] == 4, tabs[1]["panel_count"]
assert snapshot["panel_count"] == 4, snapshot["panel_count"]
print("panel counts ok; tab0={}; tab1={}; active={}".format(tabs[0]["panel_count"], tabs[1]["panel_count"], snapshot["panel_count"]))
'

close_sequence='[
  {"command_id":"tab.new"},
  {"command_id":"tab.close"},
  {"command_id":"tab.close"}
]'

close_json="$(COMMANDER_AUTOMATION_COMMANDS_JSON="$close_sequence" "$repo_dir/commander")"
printf '%s\n' "$close_json" | python3 -c '
import json
import sys

data = json.load(sys.stdin)
snapshot = data["snapshot"]
tabs = snapshot["tabs"]
assert len(tabs) == 1, len(tabs)
assert snapshot["active_tab"] == 0, snapshot["active_tab"]
assert data["status_text"] == "Cannot close the last tab", data["status_text"]
print("close guard ok; tabs={}; status={}".format(len(tabs), data["status_text"]))
'
