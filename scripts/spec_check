#!/usr/bin/env sh
set -eu

repo_dir="$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)"
failed=0

for file in "$repo_dir"/specs/*Spec.cs.md; do
  [ -f "$file" ] || continue
  for heading in "## Intent" "## MUST" "## MUST NOT"; do
    if ! grep -q "^$heading" "$file"; then
      printf 'missing %s in %s\n' "$heading" "$file" >&2
      failed=1
    fi
  done
  if ! grep -Eq '^## (Invariants|Checks)' "$file"; then
    printf 'missing Invariants/Checks section in %s\n' "$file" >&2
    failed=1
  fi
done

if find "$repo_dir/specs" -name '*.codespeak.md' -print | grep -q .; then
  printf 'old .codespeak.md spec names found; use *Spec.cs.md\n' >&2
  failed=1
fi

python3 - "$repo_dir" <<'PY' || failed=1
import os
import sys

repo = sys.argv[1]
roots = [
    os.path.join(repo, "README.md"),
    os.path.join(repo, "specs"),
    os.path.join(repo, "src"),
    os.path.join(repo, "plugins"),
    os.path.join(repo, "scripts"),
]

def has_cyrillic(text):
    return any(0x0400 <= ord(ch) <= 0x04FF for ch in text)

failed = False
for root in roots:
    if os.path.isfile(root):
        files = [root]
    else:
        files = [
            os.path.join(dirpath, name)
            for dirpath, _, names in os.walk(root)
            for name in names
        ]

    for path in files:
        try:
            with open(path, "r", encoding="utf-8") as fh:
                for line_no, line in enumerate(fh, 1):
                    if has_cyrillic(line):
                        print(f"{path}:{line_no}: non-English Cyrillic text", file=sys.stderr)
                        failed = True
        except UnicodeDecodeError:
            continue
        except FileNotFoundError:
            continue

sys.exit(1 if failed else 0)
PY

if [ "$failed" -ne 0 ]; then
  printf 'non-English Cyrillic text found in repo-facing docs, code, or scripts\n' >&2
fi

exit "$failed"
