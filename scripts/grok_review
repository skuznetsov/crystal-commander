#!/usr/bin/env sh
set -eu

repo_dir="$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)"

if [ "$#" -lt 1 ]; then
  printf 'usage: %s TASK_FILE\n' "$0" >&2
  exit 2
fi

task_file="$1"

cd "$repo_dir"
env -u GROK_CODE_XAI_API_KEY -u XAI_API_KEY \
  timeout 150 \
  scripts/grok_acp_delegate.py \
    --stream-limit-mb 32 \
    --prompt-timeout 120 \
    --request-timeout 30 \
    --task-file "$task_file"
